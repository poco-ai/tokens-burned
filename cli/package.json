{
  "name": "@poco-ai/tokenarena",
  "version": "0.4.2",
  "type": "module",
  "description": "Collect and sync local AI coding CLI usage data",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poco-ai/tokenarena.git"
  },
  "homepage": "https://github.com/poco-ai/tokenarena",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "tokenarena": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=json-summary --coverage.reporter=lcov",
    "lint": "biome check",
    "format": "biome format --write",
    "format:check": "biome format"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.0.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  }
}
